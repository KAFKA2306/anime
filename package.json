{
  "name": "kafka2306-anime",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Canonical d Anime Store catalogue and auditable attribute enrichment pipeline",
  "scripts": {
    "acquire:raw": "node scripts/acquire-danime.mjs",
    "canonicalize": "node scripts/canonicalize-from-official-json.mjs",
    "attributes:apply": "node scripts/apply-attributes.mjs",
    "attributes:enrich": "node scripts/enrich-official-details.mjs && npm run attributes:apply",
    "acquire": "npm run acquire:raw && npm run canonicalize && npm run attributes:apply",
    "validate": "node scripts/validate-data.mjs",
    "test": "node --test tests/*.test.mjs"
  },
  "dependencies": {
    "playwright": "1.61.1"
  },
  "engines": {
    "node": ">=22"
  }
}
